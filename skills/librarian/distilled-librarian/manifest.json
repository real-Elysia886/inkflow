{
  "manifest_version": "1",
  "id": "inkflow.librarian.distilled-librarian",
  "kind": "inkflow-skill",
  "skill_type": "librarian",
  "slug": "distilled-librarian",
  "display_name": "图书管理员（蒸馏作品）",
  "description": "基于都市异能/玄幻小说《未知作品》的智能图书管理员，擅长生成符合原作风格的章节摘要，追踪角色动态与伏笔网络。",
  "entrypoints": {
    "agent": "agent.py",
    "config": "config.yaml",
    "prompt": "prompt.md",
    "samples": "samples.json"
  },
  "artifacts": [
    "agent.py",
    "config.yaml",
    "prompt.md",
    "samples.json",
    "manifest.json",
    "meta.json"
  ],
  "capabilities": [
    "execute",
    "configure",
    "prompt"
  ],
  "engine": {
    "name": "inkflow",
    "version": "0.1.0",
    "skill_type": "librarian",
    "provider": "deepseek",
    "model": "deepseek-chat"
  },
  "install": {
    "compatible_runtimes": [
      "inkflow-cli",
      "claude-code"
    ],
    "min_schema_version": "1"
  }
}